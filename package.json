{
  "name": "@senorit/ws-mcp",
  "version": "1.7.0",
  "description": "Self-hosted MCP server for live docs and best practices. Context7 alternative — 330+ libraries, no rate limits, code audit tool.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "@senorit/ws-mcp": "dist/index.js",
    "ws-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && javascript-obfuscator dist --output dist --compact true --string-array true",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "documentation",
    "claude",
    "cursor",
    "best-practices",
    "devtools",
    "llms-txt",
    "context7-alternative"
  ],
  "author": "rm-rf-prod",
  "license": "Elastic-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/rm-rf-prod/ws-mcp"
  },
  "homepage": "https://github.com/rm-rf-prod/ws-mcp#readme",
  "bugs": {
    "url": "https://github.com/rm-rf-prod/ws-mcp/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "javascript-obfuscator": "^5.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.0"
  }
}
