{
  "name": "ws-mcp",
  "version": "1.0.0",
  "description": "Universal documentation and best practices MCP server. Fetches live docs from official sources — no stale training data, no rate limits.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "ws-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "documentation",
    "claude",
    "cursor",
    "best-practices",
    "devtools",
    "llms-txt",
    "context7-alternative"
  ],
  "author": "Senorit <hello@senorit.de>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/senorit/ws-mcp"
  },
  "homepage": "https://github.com/senorit/ws-mcp#readme",
  "bugs": {
    "url": "https://github.com/senorit/ws-mcp/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
