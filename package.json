{
  "name": "@senorit/ws-mcp",
  "version": "2.0.0",
  "description": "Self-hosted MCP server for live docs and best practices. Context7 alternative — 330+ libraries, no rate limits, code audit tool.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "@senorit/ws-mcp": "dist/index.js",
    "ws-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && javascript-obfuscator dist --output dist --compact true --string-array true",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "version": "node -e \"const fs=require('fs');const v=JSON.parse(fs.readFileSync('package.json','utf8')).version;const c=fs.readFileSync('src/constants.ts','utf8').replace(/SERVER_VERSION = \\\"[^\\\"]+\\\"/,`SERVER_VERSION = \\\"${v}\\\"`);fs.writeFileSync('src/constants.ts',c)\" && git add src/constants.ts"
  },
  "engines": {
    "node": ">=24"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "documentation",
    "claude",
    "cursor",
    "best-practices",
    "devtools",
    "llms-txt",
    "context7-alternative"
  ],
  "author": "rm-rf-prod",
  "license": "Elastic-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/rm-rf-prod/ws-mcp"
  },
  "homepage": "https://github.com/rm-rf-prod/ws-mcp#readme",
  "bugs": {
    "url": "https://github.com/rm-rf-prod/ws-mcp/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "javascript-obfuscator": "^5.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
